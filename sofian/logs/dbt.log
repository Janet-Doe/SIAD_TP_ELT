11:03:52.600025 [debug]: Query executed on node model.projet_bi.adresse_dim:
/* {"app": "dbt", "dbt_version": "2.0.0", "node_id": "model.projet_bi.adresse_dim", "profile_name": "projet_bi", "target_name": "dev"} */
create  table "projet_siad_elt"."silver_gold"."adresse_dim__dbt_tmp"
  
  
    as
  
  (
    

WITH zip_codes AS (
    SELECT DISTINCT 
        code_postal AS cp_full,
        CASE 
            WHEN LENGTH(code_postal) = 5 THEN 
                CASE 
                    WHEN LEFT(code_postal, 3) IN ('971', '972', '973', '974', '976') THEN LEFT(code_postal, 3)
                    ELSE LEFT(code_postal, 2)
                END
            ELSE code_postal 
        END AS dept_code
    FROM "projet_siad_elt"."silver"."silver_adhesion_detail"
    WHERE code_postal IS NOT NULL 
      AND TRIM(code_postal) NOT IN ('0', '', ' ')
      AND LENGTH(TRIM(code_postal)) >= 2
),

joined_geo AS (
    SELECT
        z.cp_full AS cp,
        d.departement,
        d.region
    FROM zip_codes z
    LEFT JOIN "projet_siad_elt"."silver"."silver_dept_region" d ON CAST(z.dept_code AS VARCHAR) = CAST(d.cp AS VARCHAR)
)

-- Règle d'or : On garantit l'unicité par CP pour atteindre 3372
SELECT DISTINCT ON (cp)
    cp,
    departement,
    region
FROM joined_geo
WHERE cp IS NOT NULL
ORDER BY cp, departement
  )
