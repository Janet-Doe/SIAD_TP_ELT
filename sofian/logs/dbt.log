create  table "projet_siad_elt"."silver_gold"."adresse_dim__dbt_tmp"
  
  
    as
  
  (
    

WITH zip_codes AS (
    -- On récupère les codes postaux uniques depuis les adhésions
    SELECT DISTINCT 
        code_postal AS cp_full,
        CASE 
            WHEN LENGTH(code_postal) = 5 THEN 
                CASE 
                    WHEN LEFT(code_postal, 3) IN ('971', '972', '973', '974', '976') THEN LEFT(code_postal, 3)
                    ELSE LEFT(code_postal, 2)
                END
            ELSE code_postal 
        END AS dept_code
    FROM "projet_siad_elt"."silver"."silver_adhesion_detail"
)

SELECT DISTINCT
    z.cp_full AS cp, -- On garde le CP complet pour atteindre 3372
    d.departement,
    d.region
FROM zip_codes z
LEFT JOIN "projet_siad_elt"."silver"."silver_dept_region" d ON CAST(z.dept_code AS VARCHAR) = CAST(d.cp AS VARCHAR)
WHERE z.cp_full IS NOT NULL
  )
