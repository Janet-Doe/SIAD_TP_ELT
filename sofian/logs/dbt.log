10:38:01.628648 [debug]: Query executed on node model.projet_bi.sinistre_fact:
/* {"app": "dbt", "dbt_version": "2.0.0", "node_id": "model.projet_bi.sinistre_fact", "profile_name": "projet_bi", "target_name": "dev"} */
create  table "projet_siad_elt"."silver_gold"."sinistre_fact__dbt_tmp"
  
  
    as
  
  (
    

WITH prestations AS (
    SELECT * FROM "projet_siad_elt"."silver"."silver_prestations_sante"
),

adhesions AS (
    -- On récupère le CP et les infos de naissance pour l'âge/ancienneté
    SELECT 
        num_adhesion_normalise,
        num_beneficiaire,
        code_postal,
        exercice_paiement,
        date_naissance_beneficiaire
    FROM "projet_siad_elt"."silver"."silver_adhesion_detail"
),

meteo AS (
    SELECT * FROM "projet_siad_elt"."silver"."silver_meteo"
),

joined AS (
    SELECT
        p.num_beneficiaire_sinistre AS benid,
        p.num_adhesion AS contratid,
        a.code_postal AS adresseid,
        p.acte AS acteid,
        p.date_soins AS datesoins,
        p.date_remboursements AS dateremb,
        
        -- Indicateurs Calculés
        (EXTRACT(YEAR FROM p.date_soins) - EXTRACT(YEAR FROM a.date_naissance_beneficiaire))::INTEGER AS age,
        (EXTRACT(YEAR FROM p.date_soins) - a.exercice_paiement)::INTEGER AS anciennete,
        
        -- Mesures
        p.frais_reel,
        p.montant_secu,
        p.montant_rembourse AS montantmut,
        
        -- Donnée météo pour enrichissement
        m.temperature
        
    FROM prestations p
    LEFT JOIN adhesions a ON p.num_adhesion = a.num_adhesion_normalise 
                         AND p.num_beneficiaire = a.num_beneficiaire
    LEFT JOIN meteo m ON CAST(
                            CASE 
                                WHEN LENGTH(a.code_postal) = 5 THEN 
                                    CASE 
                                        WHEN LEFT(a.code_postal, 3) IN ('971', '972', '973', '974', '976') THEN LEFT(a.code_postal, 3)
                                        ELSE LEFT(a.code_postal, 2)
                                    END
                                ELSE a.code_postal 
                            END 
                         AS VARCHAR) = m.cp 
                      AND p.date_soins = m.date_meteo
)

SELECT
    CAST(benid AS INTEGER) AS benid,
    CAST(contratid AS INTEGER) AS contratid,
    CAST(adresseid AS VARCHAR) AS adresseid,
    acteid,
    datesoins,
    dateremb,
    age,
    anciennete,
    frais_reel,
    montant_secu,
    montantmut,
    temperature
FROM joined
WHERE benid IS NOT NULL AND datesoins IS NOT NULL
  )
