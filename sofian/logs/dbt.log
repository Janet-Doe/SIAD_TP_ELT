/* {"app": "dbt", "dbt_version": "2.0.0", "node_id": "model.projet_bi.silver_contrat", "profile_name": "projet_bi", "target_name": "dev"} */
create  table "projet_siad_elt"."silver"."silver_contrat__dbt_tmp"
  
  
    as
  
  (
    

WITH adhesion_source AS (
    SELECT 
        NUM_ADHESION_NORMALISE AS c_id,
        FORMULE,
        TYPE_BENEFICIAIRE,
        CODE_PROFESSION
    FROM "projet_siad_elt"."public"."bronze_adhesion_detail"
),

classification_source AS (
    SELECT 
        CAST(niveau AS INTEGER) AS niveau,
        code AS code_prof,
        categorie AS categ_profession,
        famille_metier AS famille_profession,
        intitule AS libelle_profession
    FROM "projet_siad_elt"."public"."bronze_classification"
),

joined_data AS (
    SELECT
        a.c_id,
        TRIM(REGEXP_REPLACE(a.FORMULE, '\s+', ' ')) AS formule,
        SPLIT_PART(TRIM(REGEXP_REPLACE(a.FORMULE, '\s+', ' ')), ' ', 1) AS categ_formule,
        a.TYPE_BENEFICIAIRE AS type_beneficiaire,
        c.niveau,
        c.categ_profession,
        c.famille_profession,
        c.libelle_profession
    FROM adhesion_source a
    LEFT JOIN classification_source c ON TRIM(a.CODE_PROFESSION) = TRIM(c.code_prof)
)

SELECT DISTINCT
    md5(concat(
        coalesce(cast(c_id as text), ''), '-', 
        coalesce(type_beneficiaire, ''), '-',
        coalesce(formule, '')
    )) AS silver_id,
    *
FROM joined_data
WHERE c_id IS NOT NULL
  )
