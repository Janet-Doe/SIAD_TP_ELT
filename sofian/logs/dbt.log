/* {"app": "dbt", "dbt_version": "2.0.0", "node_id": "model.projet_bi.silver_adhesion_detail", "profile_name": "projet_bi", "target_name": "dev"} */
create  table "projet_siad_elt"."silver"."silver_adhesion_detail__dbt_tmp"
  
  
    as
  
  (
    

WITH raw_adhesion AS (
    SELECT * FROM "projet_siad_elt"."public"."bronze_adhesion_detail"
)

SELECT
    CAST(NUM_ADHESION_NORMALISE AS VARCHAR) AS adhesion_id,
    CAST(NUM_BENEFICIAIRE_UNIQUE AS INTEGER) AS beneficiary_id,
    TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY') AS birth_date,
    CAST(PRIMES_ACQUISES AS DECIMAL(10,2)) AS earned_premium,
    CASE 
        WHEN TYPE_BENEFICIAIRE = 'AS' THEN 'Assuré'
        WHEN TYPE_BENEFICIAIRE = 'EN' THEN 'Enfant'
        WHEN TYPE_BENEFICIAIRE = 'CJ' THEN 'Conjoint'
        ELSE 'Autre'
    END AS beneficiary_type_label,
    EXERCICE_PAIEMENT - EXTRACT(YEAR FROM TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY')) AS age_at_payment,
    UPPER(CODE_PRODUIT) AS product_code,
    UPPER(FORMULE) AS formula_name,
    CODE_POSTAL,
    EXERCICE_PAIEMENT
FROM raw_adhesion
WHERE NUM_ADHESION_NORMALISE IS NOT NULL 
  AND DATE_NAISSANCE_BENEFICIAIRE IS NOT NULL
  )
