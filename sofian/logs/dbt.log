/* {"app": "dbt", "dbt_version": "2.0.0", "node_id": "model.projet_bi.anomalies_dept_region", "profile_name": "projet_bi", "target_name": "dev"} */
create  table "projet_siad_elt"."silver"."anomalies_dept_region__dbt_tmp"
  
  
    as
  
  (
    

WITH source AS (
    SELECT * FROM "projet_siad_elt"."public"."bronze_dept_region"
)

SELECT
    *,
    CASE
        WHEN "departmentcode" IS NULL THEN 'departmentcode manquant'
        WHEN "departmentname" IS NULL THEN 'departmentname manquant'
        WHEN TRIM("departmentcode") = '' THEN 'departmentcode vide'
    END AS raison_anomalie
FROM source
WHERE "departmentcode" IS NULL 
   OR "departmentname" IS NULL
   OR TRIM("departmentcode") = ''
  )
