create  table "projet_siad_elt"."silver_gold"."beneficiaire_dim__dbt_tmp"
  
  
    as
  
  (
    

WITH benef AS (
    -- On part de la source bénéficiaire (Sexe / Régime)
    SELECT 
        CAST(num_ben_id AS INTEGER) AS b_id,
        sexe,
        regime_social
    FROM "projet_siad_elt"."silver"."silver_beneficiaire" -- On suppose que tu as ce modèle
),

adhesion AS (
    -- On récupère le type de bénéficiaire
    SELECT DISTINCT
        CAST(num_beneficiaire_unique AS INTEGER) AS b_id,
        type_beneficiaire
    FROM "projet_siad_elt"."silver"."silver_adhesion_detail"
)

SELECT DISTINCT
    b.b_id,
    b.sexe,
    b.regime_social,
    a.type_beneficiaire
FROM benef b
LEFT JOIN adhesion a ON b.b_id = a.b_id
WHERE b.b_id IS NOT NULL
