/* {"app": "dbt", "dbt_version": "2.0.0", "node_id": "model.projet_bi.anomalies_meteo", "profile_name": "projet_bi", "target_name": "dev"} */
create  table "projet_siad_elt"."silver"."anomalies_meteo__dbt_tmp"
  
  
    as
  
  (
    

WITH source AS (
    SELECT * FROM "projet_siad_elt"."public"."bronze_meteo"
)

SELECT
    *,
    CASE
        WHEN "departement" IS NULL THEN 'departement manquant'
        WHEN "date" IS NULL THEN 'date manquante'
        WHEN "tempmin" IS NULL THEN 'tempmin manquante'
        WHEN "tempmax" IS NULL THEN 'tempmax manquante'
    END AS raison_anomalie
FROM source
WHERE "departement" IS NULL 
   OR "date" IS NULL
   OR "tempmin" IS NULL
   OR "tempmax" IS NULL
  )
