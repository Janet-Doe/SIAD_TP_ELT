  -- Règle d'or : On garantit l'unicité par contrat/bénéficiaire pour éviter le produit cartésien
  deduplicated_adhesion AS (
      SELECT DISTINCT ON (NUM_ADHESION_NORMALISE, NUM_BENEFICIAIRE)
          *
      FROM raw_adhesion
      ORDER BY NUM_ADHESION_NORMALISE, NUM_BENEFICIAIRE, EXERCICE_PAIEMENT DESC
  ),
  
  clean_base AS (
      SELECT 
          *,
          TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY') AS dt_naiss_ben,
          TO_DATE(DATE_NAISSANCE_ASSURE, 'DD/MM/YYYY') AS dt_naiss_ass,
          CAST(EXERCICE_PAIEMENT AS INTEGER) AS exercice_paiement_val
      FROM deduplicated_adhesion
      WHERE NUM_ADHESION_NORMALISE IS NOT NULL
        AND DATE_NAISSANCE_BENEFICIAIRE IS NOT NULL
        AND TYPE_BENEFICIAIRE IN ('AS', 'EN', 'CO')
        AND EXERCICE_PAIEMENT IS NOT NULL
        AND CODE_POSTAL != '0'
  ),
  
  beneficiaire_clean AS (
      SELECT 
          CAST(NUM_BENEFICIAIRE AS INTEGER) AS num_ben_id,
          TRIM(SEXE) AS sexe,
          TRIM(REGIME_SOCIAL) AS regime_social
      FROM "projet_siad_elt"."silver"."silver_beneficiaire"
  ),
  
  age_calculation AS (
      SELECT 
          cb.*,
          bc.sexe,
          bc.regime_social,
          (cb.exercice_paiement_val - EXTRACT(YEAR FROM cb.dt_naiss_ben))::INTEGER AS age_val
      FROM clean_base cb
      LEFT JOIN beneficiaire_clean bc ON CAST(cb.NUM_BENEFICIAIRE_UNIQUE AS INTEGER) = bc.num_ben_id
  )
  
  SELECT
