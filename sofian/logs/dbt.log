/* {"app": "dbt", "dbt_version": "2.0.0", "node_id": "model.projet_bi.silver_prestations_sante", "profile_name": "projet_bi", "target_name": "dev"} */
create view "projet_siad_elt"."silver"."silver_prestations_sante__dbt_tmp"
    
    
  as (
    WITH clean_data AS (

    SELECT DISTINCT

        CAST(num_sinistre AS INTEGER) AS num_sinistre,
        CAST(num_adhesion AS INTEGER) AS num_adhesion,

        TRIM(acte)::VARCHAR AS acte,

        INITCAP(TRIM(designation_acte))::VARCHAR AS designation_acte,

        UPPER(TRIM(libelle_bareme))::VARCHAR AS libelle_bareme,

        CAST(num_beneficiaire AS INTEGER) AS num_beneficiaire,

        CAST(num_beneficiaire_sinistre AS INTEGER) AS num_beneficiaire_sinistre,

        MAKE_DATE(
            CAST(annee_debut_soins AS INTEGER),
            CAST(mois_debut_soins AS INTEGER),
            CAST(jour_debut_soins AS INTEGER)
        ) AS date_debut_soins,

        MAKE_DATE(
            CAST(annee_paiement AS INTEGER),
            CAST(mois_paiement AS INTEGER),
            CAST(jour_paiement AS INTEGER)
        ) AS date_paiement,

        CAST(frais_reel_assure AS FLOAT) AS frais_reel_assure,

        CAST(montant_secu AS FLOAT) AS montant_secu,

        CAST(montant_rembourse AS FLOAT) AS montant_rembourse

    FROM bronze_prestations_sante

)

SELECT *
FROM clean_data
WHERE

    frais_reel_assure >= 0
    AND montant_secu >= 0
    AND montant_rembourse >= 0

    AND montant_rembourse <= frais_reel_assure

    AND date_paiement >= date_debut_soins
  )
