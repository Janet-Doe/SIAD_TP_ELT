/* {"app": "dbt", "dbt_version": "2.0.0", "node_id": "model.projet_bi.beneficiaire_dim", "profile_name": "projet_bi", "target_name": "dev"} */
create  table "projet_siad_elt"."silver_gold"."beneficiaire_dim__dbt_tmp"
  
  
    as
  
  (
    

WITH benef AS (
    -- On part de la source bénéficiaire (Sexe / Régime)
    SELECT 
        CAST(num_ben_id AS INTEGER) AS b_id,
        sexe,
        regime_social
    FROM "projet_siad_elt"."silver"."silver_beneficiaire" -- On suppose que tu as ce modèle
),

adhesion AS (
    -- On récupère le type de bénéficiaire
    SELECT DISTINCT
        CAST(num_beneficiaire_unique AS INTEGER) AS b_id,
        type_beneficiaire
    FROM "projet_siad_elt"."silver"."silver_adhesion_detail"
)

SELECT DISTINCT
    b.b_id,
    b.sexe,
    b.regime_social,
    a.type_beneficiaire
FROM benef b
LEFT JOIN adhesion a ON b.b_id = a.b_id
WHERE b.b_id IS NOT NULL
  )
11:00:43.045363 [debug]: Query executed on node model.projet_bi.adresse_dim:
/* {"app": "dbt", "dbt_version": "2.0.0", "node_id": "model.projet_bi.adresse_dim", "profile_name": "projet_bi", "target_name": "dev"} */
create  table "projet_siad_elt"."silver_gold"."adresse_dim__dbt_tmp"
  
  
    as
  
  (
    

WITH zip_codes AS (
    SELECT DISTINCT 
        code_postal AS cp_full,
        CASE 
            WHEN LENGTH(code_postal) = 5 THEN 
                CASE 
                    WHEN LEFT(code_postal, 3) IN ('971', '972', '973', '974', '976') THEN LEFT(code_postal, 3)
                    ELSE LEFT(code_postal, 2)
                END
            ELSE code_postal 
        END AS dept_code
    FROM "projet_siad_elt"."silver"."silver_adhesion_detail"
    -- Filtre d'exclusion strict pour arriver à 3372
    WHERE code_postal IS NOT NULL 
      AND TRIM(code_postal) NOT IN ('0', '', ' ')
      AND LENGTH(TRIM(code_postal)) >= 2
)

SELECT DISTINCT
    z.cp_full AS cp,
    d.departement,
    d.region
FROM zip_codes z
LEFT JOIN "projet_siad_elt"."silver"."silver_dept_region" d ON CAST(z.dept_code AS VARCHAR) = CAST(d.cp AS VARCHAR)
WHERE z.cp_full IS NOT NULL
  )
