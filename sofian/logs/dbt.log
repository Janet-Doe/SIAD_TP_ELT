        TYPE_BENEFICIAIRE AS type_beneficiaire,
        CODE_PROFESSION AS code_profession
    FROM adhesion_source
)

SELECT
    md5(concat(
        coalesce(cast(num_adhesion_normalise as text), ''), '-', 
        coalesce(type_beneficiaire, ''), '-',
        coalesce(formule, ''),
        cast(row_number() over() as text)
    )) AS silver_id,
    *
FROM cleaned_data
  );
  
