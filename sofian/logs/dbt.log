        WHEN CAST(EXERCICE_PAIEMENT AS INTEGER) - EXTRACT(YEAR FROM TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY'))::INTEGER BETWEEN 3 AND 11 THEN 'Enfant'
        WHEN CAST(EXERCICE_PAIEMENT AS INTEGER)
            - EXTRACT(YEAR FROM TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY'))::INTEGER BETWEEN 12 AND 14
            THEN 'Pré-adolescent'
        WHEN CAST(EXERCICE_PAIEMENT AS INTEGER)
            - EXTRACT(YEAR FROM TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY'))::INTEGER BETWEEN 15 AND 17
            THEN 'Adolescent'
        WHEN CAST(EXERCICE_PAIEMENT AS INTEGER)
            - EXTRACT(YEAR FROM TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY'))::INTEGER BETWEEN 18 AND 25
            THEN 'Jeune adulte'
        WHEN CAST(EXERCICE_PAIEMENT AS INTEGER)
            - EXTRACT(YEAR FROM TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY'))::INTEGER BETWEEN 26 AND 59
            THEN 'Adulte'
        ELSE 'Senior'
    END AS gp_age
FROM clean_data
  )
