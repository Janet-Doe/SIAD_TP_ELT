21:12:36.882947 [debug]: Query executed on node model.projet_bi.silver_adhesion_detail:
/* {"app": "dbt", "dbt_version": "2.0.0", "node_id": "model.projet_bi.silver_adhesion_detail", "profile_name": "projet_bi", "target_name": "dev"} */
create  table "projet_siad_elt"."silver"."silver_adhesion_detail__dbt_tmp"
  
  
    as
  
  (
    

WITH clean_data AS (
    SELECT * FROM "projet_siad_elt"."public"."bronze_adhesion_detail"
    WHERE NUM_ADHESION_NORMALISE IS NOT NULL
      AND DATE_NAISSANCE_BENEFICIAIRE IS NOT NULL
      AND TYPE_BENEFICIAIRE IN ('AS', 'EN', 'CO')
      AND EXERCICE_PAIEMENT IS NOT NULL
      AND CODE_POSTAL != '0'
      AND CAST(PRIMES_ACQUISES AS DECIMAL(10,2)) >= 0
      AND (
            CAST(EXERCICE_PAIEMENT AS INTEGER)
            - EXTRACT(YEAR FROM TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY'))::INTEGER
        ) >= 0
)

SELECT
    md5(concat(
        coalesce(cast(NUM_ADHESION_NORMALISE as text), ''), '-',
        coalesce(cast(NUM_BENEFICIAIRE_UNIQUE as text), ''), '-',
        coalesce(cast(EXERCICE_PAIEMENT as text), '')
    )) AS silver_id,
    CAST(NUM_ADHESION_NORMALISE AS INTEGER) AS num_adhesion_normalise,
    CAST(NUM_BENEFICIAIRE_UNIQUE AS INTEGER) AS num_beneficiaire_unique,
    TO_DATE(DATE_NAISSANCE_ASSURE, 'DD/MM/YYYY') AS date_naissance_assure,
    CAST(CODE_POSTAL AS INTEGER) AS code_postal,
    CAST(EXERCICE_PAIEMENT AS INTEGER) AS exercice_paiement,
    CAST(NUM_BENEFICIAIRE AS INTEGER) AS num_beneficiaire,
    TYPE_BENEFICIAIRE AS type_beneficiaire,
    CASE
        WHEN TYPE_BENEFICIAIRE = 'AS' THEN 'Assuré principal'
        WHEN TYPE_BENEFICIAIRE = 'EN' THEN 'Enfant'
        WHEN TYPE_BENEFICIAIRE = 'CO' THEN 'Conjoint'
        ELSE 'Autre'
    END AS type_beneficiaire_libelle,
    TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY') AS date_naissance_beneficiaire,
    UPPER(CODE_PROFESSION) AS code_profession,
    CODE_PRODUIT AS code_produit,
    CASE
        WHEN CODE_PRODUIT = 'C' THEN 'Collectif'
        WHEN CODE_PRODUIT = 'M' THEN 'Individuel'
        ELSE 'Inconnu'
    END AS code_produit_libelle,
    CODE_FRACTIONNEMENT AS code_fractionnement,
    CASE
        WHEN CODE_FRACTIONNEMENT = 'A' THEN 'Annuel'
        WHEN CODE_FRACTIONNEMENT = 'S' THEN 'Semestriel'
        WHEN CODE_FRACTIONNEMENT = 'T' THEN 'Trimestriel'
        WHEN CODE_FRACTIONNEMENT = 'M' THEN 'Mensuel'
        WHEN CODE_FRACTIONNEMENT = 'P' THEN 'Unique'
        ELSE 'Inconnu'
    END AS code_fractionnement_libelle,
    CODE_GARANTIE AS code_garantie,
    --supprime les espaces multiples dans formule
    TRIM(REGEXP_REPLACE(FORMULE, '\s+', ' ')) AS formule,
    --garde juste le premier mot (avant l'espace)
    SPLIT_PART(TRIM(REGEXP_REPLACE(FORMULE, '\s+', ' ')), ' ', 1) AS categ_formule,
    CAST(PRIMES_ACQUISES AS DECIMAL(10,2)) AS primes_acquises,
    CAST(CODE_AGENT AS BIGINT) AS code_agent,
    CAST(CODE_REGION AS INTEGER) AS code_region,
    PRIME_GARANTIE AS prime_garantie,
    CAST(EXERCICE_PAIEMENT AS INTEGER) - EXTRACT(YEAR FROM TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY'))::INTEGER AS age_a_l_exercice,
    CASE
        WHEN CAST(EXERCICE_PAIEMENT AS INTEGER)
            - EXTRACT(YEAR FROM TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY'))::INTEGER BETWEEN 0 AND 2
            THEN 'Nourrisson'
        WHEN CAST(EXERCICE_PAIEMENT AS INTEGER)
            - EXTRACT(YEAR FROM TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY'))::INTEGER BETWEEN 3 AND 11
            THEN 'Enfant'
        WHEN CAST(EXERCICE_PAIEMENT AS INTEGER)
            - EXTRACT(YEAR FROM TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY'))::INTEGER BETWEEN 12 AND 14
            THEN 'Pré-adolescent'
        WHEN CAST(EXERCICE_PAIEMENT AS INTEGER)
            - EXTRACT(YEAR FROM TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY'))::INTEGER BETWEEN 15 AND 17
            THEN 'Adolescent'
        WHEN CAST(EXERCICE_PAIEMENT AS INTEGER)
            - EXTRACT(YEAR FROM TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY'))::INTEGER BETWEEN 18 AND 25
            THEN 'Jeune adulte'
        WHEN CAST(EXERCICE_PAIEMENT AS INTEGER)
            - EXTRACT(YEAR FROM TO_DATE(DATE_NAISSANCE_BENEFICIAIRE, 'DD/MM/YYYY'))::INTEGER BETWEEN 26 AND 59
            THEN 'Adulte'
        ELSE 'Senior'
    END AS categ_age
FROM clean_data
  )
