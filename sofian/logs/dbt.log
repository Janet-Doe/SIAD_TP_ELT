/* {"app": "dbt", "dbt_version": "2.0.0", "node_id": "model.projet_bi.sinistre_fact", "profile_name": "projet_bi", "target_name": "dev"} */
create  table "projet_siad_elt"."silver_gold"."sinistre_fact__dbt_tmp"
  
  
    as
  
  (
    

WITH prestations_agg AS (
    -- On agrège les montants par contrat pour ne pas multiplier les lignes
    SELECT 
        num_adhesion,
        num_beneficiaire,
        MAX(acte) AS acteid, -- On prend l'acte principal
        MAX(date_soins) AS datesoins,
        MAX(date_remboursements) AS dateremb,
        SUM(frais_reel) AS frais_reel,
        SUM(montant_secu) AS montant_secu,
        SUM(montant_rembourse) AS montantmut
    FROM "projet_siad_elt"."silver"."silver_prestations_sante"
    GROUP BY num_adhesion, num_beneficiaire
),

adhesions AS (
    -- Notre base de 83 232 lignes
    SELECT * FROM "projet_siad_elt"."silver"."silver_adhesion_detail"
),

meteo AS (
    SELECT * FROM "projet_siad_elt"."silver"."silver_meteo"
),

joined AS (
    SELECT
        a.num_beneficiaire_unique AS benid,
        a.num_adhesion_normalise AS contratid,
        a.code_postal AS adresseid,
        COALESCE(p.acteid, 'N/A') AS acteid,
        COALESCE(p.datesoins, TO_DATE(a.exercice_paiement || '-01-01', 'YYYY-MM-DD')) AS datesoins,
        p.dateremb,
        
        a.age AS age_id,
        (a.exercice_paiement - 2010) AS anciennete,
        
        COALESCE(p.frais_reel, 0) AS frais_reel,
        COALESCE(p.montant_secu, 0) AS montant_secu,
        COALESCE(p.montantmut, 0) AS montantmut,
        
        m.temperature
        
    FROM adhesions a
    LEFT JOIN prestations_agg p ON a.num_adhesion_normalise = p.num_adhesion 
                               AND a.num_beneficiaire = p.num_beneficiaire
    LEFT JOIN meteo m ON CAST(
                            CASE 
                                WHEN LENGTH(a.code_postal) = 5 THEN 
                                    CASE 
                                        WHEN LEFT(a.code_postal, 3) IN ('971', '972', '973', '974', '976') THEN LEFT(a.code_postal, 3)
                                        ELSE LEFT(a.code_postal, 2)
                                    END
                                ELSE a.code_postal 
                            END 
                         AS VARCHAR) = m.cp 
                      AND COALESCE(p.datesoins, TO_DATE(a.exercice_paiement || '-01-01', 'YYYY-MM-DD')) = m.date_meteo
)

-- On garantit les 83 232 lignes finales
SELECT
    CAST(benid AS INTEGER) AS benid,
    CAST(contratid AS INTEGER) AS contratid,
    CAST(adresseid AS VARCHAR) AS adresseid,
    acteid,
    datesoins,
    dateremb,
    age_id,
    CAST(anciennete AS INTEGER) AS anciennete,
    frais_reel,
    montant_secu,
    montantmut,
    temperature
FROM joined
  )
