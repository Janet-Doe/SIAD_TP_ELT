10:43:19.290915 [debug]: Query executed on node model.projet_bi.silver_beneficiaire:
/* {"app": "dbt", "dbt_version": "2.0.0", "node_id": "model.projet_bi.silver_beneficiaire", "profile_name": "projet_bi", "target_name": "dev"} */
create  table "projet_siad_elt"."silver"."silver_beneficiaire__dbt_tmp"
  
  
    as
  
  (
    

WITH raw_data AS (
    SELECT * FROM "projet_siad_elt"."public"."bronze_beneficiaire"
),

cleaned_data AS (
    SELECT
        CAST(num_beneficiaire AS INTEGER) AS num_ben_id,
        CASE 
            WHEN TRIM(sexe) = 'M' THEN 'Homme'
            WHEN TRIM(sexe) = 'F' THEN 'Femme'
            ELSE TRIM(sexe)
        END AS sexe,
        TRIM(regime_social) AS regime_social
    FROM raw_data
    WHERE num_beneficiaire IS NOT NULL
)

SELECT DISTINCT
    md5(cast(num_ben_id as text)) AS silver_id,
    *
FROM cleaned_data
